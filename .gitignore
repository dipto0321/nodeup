# Node — only used for commitlint local validation. CI runs commitlint
# via wagoid/commitlint-github-action (a Docker action) so we don't
# need a package.json. Developers running `npx commitlint` locally
# install into a throwaway node_modules.
node_modules/
package-lock.json

# Tooling session metadata (not part of the project source tree).
# `.claude/skills/` is intentionally NOT ignored — it holds
# project-local AI skills (e.g. issue-workflow) that should be
# committed so any contributor/clone picks them up. Only the rest
# of `.claude/` (e.g. session settings) is ignored.
.claude/*
!.claude/skills/

.conversation-history
.puku-cli
